CONFIG_PACKAGE_luci-theme-bootstrap=y  # Bootstrap 默认主题

### 网络服务与其它软件包 ###
CONFIG_PACKAGE_microsocks=m  # 轻量 SOCKS5 代理
CONFIG_PACKAGE_miniupnpd-nftables=y  # miniupnpd UPnP IGD（nftables 版）
CONFIG_PACKAGE_mount-utils=m  # 挂载工具集
CONFIG_PACKAGE_resolveip=m  # 域名解析 IP 工具
CONFIG_PACKAGE_rpcd=y  # OpenWrt RPC 守护进程
CONFIG_PACKAGE_rpcd-mod-file=y  # rpcd 文件操作模块
CONFIG_PACKAGE_rpcd-mod-iwinfo=y  # rpcd 无线信息模块
CONFIG_PACKAGE_rpcd-mod-luci=y  # rpcd LuCI 模块
CONFIG_PACKAGE_rpcd-mod-rrdns=y  # rpcd 反向 DNS 模块
CONFIG_PACKAGE_rpcd-mod-ucode=y  # rpcd ucode 模块
CONFIG_PACKAGE_runc=m  # OCI 容器运行时 runc
CONFIG_PACKAGE_samba4-libs=m  # Samba4 库
CONFIG_PACKAGE_samba4-server=m  # Samba4 文件共享服务
CONFIG_PACKAGE_sing-box=y  # Sing-box 通用代理平台
CONFIG_PACKAGE_sqm-scripts=y  # SQM 脚本（智能队列管理）
CONFIG_PACKAGE_tc-tiny=y  # 精简版 tc 流量控制
CONFIG_PACKAGE_tcping=m  # TCP ping 连通性测试
CONFIG_PACKAGE_tini=m  # 容器 init 进程 tini
CONFIG_PACKAGE_ttyd=y  # ttyd Web 终端服务
CONFIG_PACKAGE_ucode-mod-html=y  # ucode HTML 模块
CONFIG_PACKAGE_ucode-mod-lua=y  # ucode Lua 互操作
CONFIG_PACKAGE_ucode-mod-math=y  # ucode 数学模块
CONFIG_PACKAGE_uhttpd=y  # uHTTPd Web 服务器
CONFIG_PACKAGE_uhttpd-mod-ubus=y  # uHTTPd ubus 接口
CONFIG_PACKAGE_unzip=m  # ZIP 解压工具
CONFIG_PACKAGE_wsdd2=m  # WS-Discovery（Samba Windows 发现）
CONFIG_PACKAGE_xray-core=m  # Xray 代理内核
CONFIG_PACKAGE_xtables-nft=y  # xtables nft 兼容工具
CONFIG_PACKAGE_zerotier=y  # ZeroTier SD-WAN 客户端
CONFIG_PACKAGE_zram-swap=y  # ZRAM 内存压缩交换

### Samba 与 Sing-box 编译选项 ###
CONFIG_SAMBA4_SERVER_AVAHI=y  # Samba Avahi 服务发布
CONFIG_SAMBA4_SERVER_NETBIOS=y  # Samba NetBIOS 名称
CONFIG_SAMBA4_SERVER_VFS=y  # Samba 虚拟文件系统插件
CONFIG_SAMBA4_SERVER_WSDD2=y  # Samba WS-Discovery 守护进程
CONFIG_SING_BOX_BUILD_ACME=y  # Sing-box ACME 自动证书
CONFIG_SING_BOX_BUILD_CLASH_API=y  # Sing-box Clash API 兼容
CONFIG_SING_BOX_BUILD_ECH=y  # Sing-box ECH 加密 ClientHello
CONFIG_SING_BOX_BUILD_GVISOR=y  # Sing-box gVisor 网络栈
CONFIG_SING_BOX_BUILD_QUIC=y  # Sing-box QUIC 协议
CONFIG_SING_BOX_BUILD_REALITY_SERVER=y  # Sing-box REALITY 服务端
CONFIG_SING_BOX_BUILD_UTLS=y  # Sing-box uTLS 指纹伪装
CONFIG_SING_BOX_BUILD_WIREGUARD=y  # Sing-box WireGuard 出站
# CONFIG_TARGET_ROOTFS_INITRAMFS is not set  # 不生成 initramfs 镜像
CONFIG_boost-compile-visibility-hidden=y  # Boost 隐藏符号可见性
CONFIG_boost-runtime-shared=y  # Boost 共享运行时
CONFIG_boost-static-and-shared-libs=y  # Boost 静态+动态库
CONFIG_boost-variant-release=y  # Boost Release 变体
# CONFIG_PACKAGE_kmod-crypto-kpp is not set  # 禁用内核 crypto KPP
