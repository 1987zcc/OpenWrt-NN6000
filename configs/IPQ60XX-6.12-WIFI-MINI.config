### 目标平台与设备 ###
# IPQ60xx MINI 固件编译配置，配合 IPQ60XX-6.12-WIFI-MINI.sh 使用
# NN6000 v1：IPQ6000 / 1GB RAM / QCA8075（2 LAN + 1 WAN）/ WiFi 2.4+5GHz AX
# NN6000 v2：IPQ6000 / 2GB RAM / QCA8075（4 LAN + 1 WAN）/ WiFi 2.4+5GHz AX
# 512M 内存设备需 ath11k 512M 配置 + NSS 固件 12.2（LiBwrt main-nss 已集成）
CONFIG_TARGET_qualcommax=y  # 高通 ARM64 路由器目标平台（qualcommax）
CONFIG_TARGET_qualcommax_ipq60xx=y  # IPQ60xx 子目标（含 IPQ6018/IPQ6028 等）
CONFIG_TARGET_MULTI_PROFILE=y  # 多 Profile 模式，一次编译多款设备固件
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_anysafe_e1=y  # AnySafe E1
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_cmiot_ax18=y  # 中移 AX18
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_glinet_gl-ax1800=y  # GL.iNet GL-AX1800
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_glinet_gl-axt1800=y  # GL.iNet GL-AXT1800
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_jdcloud_re-cs-02=y  # 京东云 RE-CS-02
CONFIG_TARGET_DEVICE_PACKAGES_qualcommax_ipq60xx_DEVICE_jdcloud_re-cs-02="luci-app-athena-led luci-i18n-athena-led-zh-cn"  # 京东云 RE-CS-02 额外预装 Athena LED 插件
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_jdcloud_re-ss-01=y  # 京东云 RE-SS-01
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_link_nn6000-v1=y  # Link NN6000 v1
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_link_nn6000-v2=y  # Link NN6000 v2
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_linksys_mr7350=y  # Linksys MR7350
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_linksys_mr7500=y  # Linksys MR7500
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_qihoo_360v6=y  # 360 路由器 V6
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_redmi_ax5=y  # 红米 AX5
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_redmi_ax5-jdcloud=y  # 红米 AX5 京东云版
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_xiaomi_ax1800=y  # 小米 AX1800
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_zn_m2=y  # ZN M2
CONFIG_BUSYBOX_CUSTOM=y  # 启用 Busybox 自定义配置
CONFIG_TARGET_PER_DEVICE_ROOTFS=y  # 为每个设备生成独立 rootfs
# CONFIG_ATH11K_MEM_PROFILE_1G is not set  # 禁用 1G WiFi 内存配置（ath11k）
CONFIG_ATH11K_MEM_PROFILE_512M=y  # ath11k WiFi 驱动 512M 内存配置
# CONFIG_BUSYBOX_CONFIG_FEATURE_IPV6 is not set  # Busybox 禁用 IPv6 功能
CONFIG_BUSYBOX_CONFIG_LSUSB=y  # Busybox 启用 lsusb

### 编译与性能选项 ###
CONFIG_COREMARK_ENABLE_MULTITHREADING=y  # CoreMark 多线程测试
CONFIG_COREMARK_NUMBER_OF_THREADS=16  # CoreMark 线程数 16
CONFIG_COREMARK_OPTIMIZE_O3=y  # CoreMark 使用 -O3 优化编译
CONFIG_DOCKER_CGROUP_OPTIONS=y  # Docker cgroup 支持
CONFIG_DOCKER_NET_MACVLAN=y  # Docker macvlan 网络
CONFIG_DOCKER_OPTIONAL_FEATURES=y  # Docker 可选特性
CONFIG_DOCKER_STO_EXT4=y  # Docker 存储驱动 ext4
CONFIG_GNUTLS_ALPN=y  # GnuTLS ALPN 扩展
CONFIG_GNUTLS_ANON=y  # GnuTLS 匿名认证
CONFIG_GNUTLS_DTLS_SRTP=y  # GnuTLS DTLS-SRTP
CONFIG_GNUTLS_HEARTBEAT=y  # GnuTLS 心跳
CONFIG_GNUTLS_OCSP=y  # GnuTLS OCSP 在线证书状态
CONFIG_GNUTLS_PSK=y  # GnuTLS 预共享密钥 PSK
# CONFIG_IPQ_MEM_PROFILE_1024 is not set  # 禁用 IPQ 1024M 内存配置
CONFIG_IPQ_MEM_PROFILE_512=y  # IPQ 平台 512M 内存配置
CONFIG_KERNEL_ARM_PMU=y  # ARM 性能监控单元 PMU
CONFIG_KERNEL_CFQ_GROUP_IOSCHED=y  # CFQ 分组 I/O 调度器
CONFIG_KERNEL_CGROUP_DEVICE=y  # cgroup 设备控制
CONFIG_KERNEL_CGROUP_FREEZER=y  # cgroup 进程冻结
CONFIG_KERNEL_CGROUP_HUGETLB=y  # cgroup 大页内存
CONFIG_KERNEL_CGROUP_NET_PRIO=y  # cgroup 网络优先级
CONFIG_KERNEL_CGROUP_PERF=y  # cgroup 性能事件
CONFIG_KERNEL_HUGETLBFS=y  # 大页文件系统 Hugetlbfs
CONFIG_KERNEL_HUGETLB_PAGE=y  # 大页内存支持
CONFIG_KERNEL_IPQ_MEM_PROFILE=512  # 内核 IPQ 内存配置 512MB
CONFIG_KERNEL_MEMCG_SWAP_ENABLED=y  # 内存 cgroup 交换支持
CONFIG_KERNEL_NET_CLS_CGROUP=y  # 网络 cgroup 分类
CONFIG_KERNEL_PERF_EVENTS=y  # perf 性能事件
CONFIG_KERNEL_TRANSPARENT_HUGEPAGE=y  # 透明大页 THP
CONFIG_KERNEL_TRANSPARENT_HUGEPAGE_ALWAYS=y  # 始终启用透明大页
CONFIG_KERNEL_ZRAM_BACKEND_LZO=y  # ZRAM 压缩后端 LZO
CONFIG_KERNEL_ZRAM_DEF_COMP_LZORLE=y  # ZRAM 默认 LZO-RLE 压缩
CONFIG_LIBCURL_COOKIES=y  # libcurl Cookie 支持
CONFIG_LIBCURL_CRYPTO_AUTH=y  # libcurl 加密认证
CONFIG_LIBCURL_FILE=y  # libcurl file:// 协议
CONFIG_LIBCURL_FTP=y  # libcurl FTP 协议
CONFIG_LIBCURL_HTTP=y  # libcurl HTTP 协议
CONFIG_LIBCURL_NGHTTP2=y  # libcurl HTTP/2
CONFIG_LIBCURL_OPENSSL=y  # libcurl OpenSSL 后端
CONFIG_LIBCURL_PROXY=y  # libcurl 代理支持
CONFIG_LIBCURL_TFTP=y  # libcurl TFTP 协议
CONFIG_LIBCURL_THREADED_RESOLVER=y  # libcurl 多线程 DNS 解析
CONFIG_LIBCURL_TLS_SRP=y  # libcurl TLS-SRP
CONFIG_LIBCURL_UNIX_SOCKETS=y  # libcurl Unix 域套接字
CONFIG_LUCI_LANG_zh_Hans=y  # LuCI 简体中文语言包

### NSS 网络加速 ###
CONFIG_NSS_DRV_IGS_ENABLE=y  # NSS 桥接/交换加速 IGS
CONFIG_NSS_DRV_L2TP_ENABLE=y  # NSS L2TP 硬件加速
CONFIG_NSS_DRV_LAG_ENABLE=y  # NSS 链路聚合 LAG
CONFIG_NSS_DRV_MAPT_ENABLE=y  # NSS MAP-T 转换加速
CONFIG_NSS_DRV_PPTP_ENABLE=y  # NSS PPTP 加速
CONFIG_NSS_DRV_PVXLAN_ENABLE=y  # NSS VXLAN 加速
CONFIG_NSS_DRV_SHAPER_ENABLE=y  # NSS 流量整形 Shaper
CONFIG_NSS_DRV_VXLAN_ENABLE=y  # NSS VXLAN 隧道加速
CONFIG_NSS_FIRMWARE_VERSION_12_2=y  # NSS 固件版本 12.2
# CONFIG_NSS_FIRMWARE_VERSION_12_5 is not set  # 不选 NSS 固件 12.5

### 基础软件包 ###
CONFIG_PACKAGE_6rd=y  # 6rd IPv6 过渡机制
CONFIG_PACKAGE_attr=m  # 扩展文件属性工具 attr
CONFIG_PACKAGE_avahi-dbus-daemon=m  # Avahi mDNS/DNS-SD 服务发现
CONFIG_PACKAGE_block-mount=y  # 块设备挂载工具
CONFIG_PACKAGE_boost=m  # Boost C++ 库
CONFIG_PACKAGE_boost-program_options=m  # Boost 命令行选项库
CONFIG_PACKAGE_boost-system=m  # Boost system 库
CONFIG_PACKAGE_btrfs-progs=m  # Btrfs 文件系统工具
CONFIG_PACKAGE_ca-certificates=m  # CA 根证书包
CONFIG_PACKAGE_cgi-io=y  # LuCI CGI 上传下载
CONFIG_PACKAGE_cgroupfs-mount=m  # cgroup 文件系统挂载
CONFIG_PACKAGE_chinadns-ng=y  # ChinaDNS-NG 智能 DNS 分流
CONFIG_PACKAGE_containerd=m  # containerd 容器运行时
CONFIG_PACKAGE_coremark=y  # CPU 性能基准测试工具 CoreMark
CONFIG_PACKAGE_coreutils=m  # GNU coreutils 核心工具
CONFIG_PACKAGE_coreutils-base64=m  # base64 编码工具
CONFIG_PACKAGE_coreutils-nohup=m  # nohup 后台运行
CONFIG_PACKAGE_curl=m  # curl 命令行 HTTP 客户端
CONFIG_PACKAGE_dbus=m  # D-Bus 消息总线
CONFIG_PACKAGE_ddns-scripts=y  # 动态 DNS 更新脚本
CONFIG_PACKAGE_ddns-scripts-services=y  # DDNS 各服务商脚本
CONFIG_PACKAGE_default-settings=y  # ImmortalWrt 默认设置
CONFIG_PACKAGE_default-settings-chn=y  # 中国区默认设置（时区、镜像源等）
CONFIG_PACKAGE_dns2socks=m  # DNS 转 SOCKS 代理
CONFIG_PACKAGE_dns2tcp=m  # DNS 转 TCP 隧道
CONFIG_PACKAGE_docker=m  # Docker CLI
CONFIG_PACKAGE_docker-compose=m  # Docker Compose
CONFIG_PACKAGE_dockerd=m  # Docker 守护进程
CONFIG_PACKAGE_etherwake=y  # etherwake 网络唤醒工具
CONFIG_PACKAGE_firewall=m  # 防火墙配置脚本 firewall3/4
CONFIG_PACKAGE_geoview=m  # GeoIP/GeoSite 数据查看（代理用）
CONFIG_PACKAGE_hysteria=m  # Hysteria 代理内核
CONFIG_PACKAGE_ip-full=m  # 完整版 ip 路由工具
CONFIG_PACKAGE_ip-tiny=y  # 精简版 ip 工具
CONFIG_PACKAGE_ip6tables-nft=m  # IPv6 nftables 规则
CONFIG_PACKAGE_iperf3=y  # iperf3 网络带宽测速
CONFIG_PACKAGE_ipt2socks=m  # iptables 转 SOCKS
CONFIG_PACKAGE_iptables-mod-extra=m  # iptables 扩展匹配模块
CONFIG_PACKAGE_iptables-mod-fullconenat=y  # iptables 全锥形 NAT 模块
CONFIG_PACKAGE_iptables-mod-ipopt=y  # iptables IP 选项模块
CONFIG_PACKAGE_iptables-nft=y  # iptables nft 后端

