CONFIG_PACKAGE_luci-light=y  # LuCI 精简版
CONFIG_PACKAGE_luci-lua-runtime=y  # LuCI Lua 运行时
CONFIG_PACKAGE_luci-mod-admin-full=y  # LuCI 完整管理界面
